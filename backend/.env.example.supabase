# Supabase FREE Remote Database Configuration
# Copy to backend/.env.supabase and update with your Supabase connection details
# Then activate: cp backend/.env.supabase backend/.env

APP_ENV=dev
HTTP_ADDR=:8080

# PostgreSQL - SUPABASE (100% FREE)
# Get these from: https://supabase.com/dashboard → Your Project → Connect
DB_HOST=aws-0-YOUR-REGION.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_ID
DB_PASSWORD=YOUR_SUPABASE_PASSWORD
DB_SSLMODE=require
DB_MAX_CONNS=4

# JWT
JWT_SECRET=CHANGE_ME_DEV_ONLY
