# Remote Development Configuration
# Copy to backend/.env.remote and update with your VPS details
# Then activate: cp backend/.env.remote backend/.env

APP_ENV=dev
HTTP_ADDR=:8080

# PostgreSQL - REMOTE (hosted on VPS)
DB_HOST=YOUR_VPS_IP_HERE
DB_PORT=5432
DB_NAME=dms
DB_USER=dms
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DB_SSLMODE=disable
DB_MAX_CONNS=4

# JWT
JWT_SECRET=CHANGE_ME_DEV_ONLY
